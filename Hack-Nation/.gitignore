# Environments
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
site/

# ── Clinical data must never be committed ──────────────────────────────
# Raw data lives outside the repository. Only synthetic fixtures under
# tests/fixtures/ and examples/ are tracked.
data/
raw/
private/

# ...but `data/` also matched `configs/data/`, which holds no data at all — only
# the YAML that says WHERE data lives. The effect was that every
# configs/data/*.yaml was untracked, so a fresh clone was missing the configs
# that README.md, TRAINING.md and the Slurm templates tell people to pass to
# --config. Re-include the directory; the patterns above still cover any real
# data directory anywhere else in the tree.
!configs/data/
*.dcm
*.dicom
*.nii
*.nii.gz
*.wav
*.mp3
*.m4a
*.flac
*.pdf
!examples/**/*.pdf
!tests/fixtures/**/*.pdf

# Experiment outputs are reproducible from config + commit; only manifests and
# model cards are worth tracking.
artifacts/checkpoints/
artifacts/experiments/
artifacts/figures/
*.parquet
*.ckpt
*.pt
*.pth
*.joblib
!artifacts/encoders/**/*.joblib
*.pkl

# Local
.env
.DS_Store
.idea/
.vscode/
