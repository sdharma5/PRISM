# Copy to .env. Never commit .env.
# PRISM needs no credentials to run its tests — every fixture is synthetic.
#
# ---------------------------------------------------------------------------
# NOTHING AUTO-LOADS THIS FILE.
#
# PRISM deliberately does not depend on python-dotenv; the scripts read
# os.environ directly. A .env that is silently loaded in some entry points and
# not others is worse than none at all, because the same command then behaves
# differently depending on how it was started.
#
# So this file is a convenience for humans, and you must load it yourself:
#
#     set -a; source .env; set +a          # export everything in this file
#
# or export the variables individually, or pass the equivalent CLI flags.
# Under Slurm, slurm/prism.env is the file that gets sourced.
#
# ---------------------------------------------------------------------------
# Precedence, highest first, for every setting that has a flag:
#
#     explicit CLI flag  >  environment variable  >  config file value  >  default
#
# So --data-root beats $PRISM_DATA_ROOT, which beats `data.root` in the YAML.
# ---------------------------------------------------------------------------

# Where externally downloaded datasets live (outside the repository).
# Equivalent CLI flag: --data-root
PRISM_DATA_ROOT=/path/to/local/data

# Where artifacts are written. Equivalent CLI flag: --output-dir
# Leave unset to use each experiment's configured directory, which defaults to
# artifacts/experiments/<experiment_id>.
# PRISM_ARTIFACT_ROOT=artifacts

# Optional: dataset-specific roots.
#
# NOTE: these are documentation of the expected layout, not inputs the code
# reads. Only PRISM_DATA_ROOT and PRISM_ARTIFACT_ROOT are consulted by the
# scripts. Point an individual dataset somewhere else with --data-root, or with
# `data.root` / `data.path` in the relevant configs/data/*.yaml.
PRISM_PCOS_TABULAR_PATH=${PRISM_DATA_ROOT}/pcos_tabular/pcos_data.csv
PRISM_MCPHASES_ROOT=${PRISM_DATA_ROOT}/mcphases
PRISM_NHANES_ROOT=${PRISM_DATA_ROOT}/nhanes_2021_2023
PRISM_USOVA3D_ROOT=${PRISM_DATA_ROOT}/usova3d

# Optional: speech transcription backend (the offline scripted adapter is default)
# PRISM_WHISPER_MODEL=base.en
