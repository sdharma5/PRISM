#!/usr/bin/env bash
# Cluster-specific settings. Edit ONCE, then every sbatch template picks these up.
# Nothing here is repo-specific — it is the seam between PRISM and your cluster.

# --- Paths ------------------------------------------------------------------
export PRISM_REPO="${PRISM_REPO:-$HOME/prism-hormonal-health}"
export PRISM_DATA_ROOT="${PRISM_DATA_ROOT:-/scratch/$USER/prism-data}"
export PRISM_ARTIFACT_ROOT="${PRISM_ARTIFACT_ROOT:-/scratch/$USER/prism-artifacts}"

# --- Scheduler --------------------------------------------------------------
# Set these to real values from `sinfo -s` on your cluster.
export PRISM_CPU_PARTITION="${PRISM_CPU_PARTITION:-cpu}"
export PRISM_GPU_PARTITION="${PRISM_GPU_PARTITION:-gpu}"
export PRISM_ACCOUNT="${PRISM_ACCOUNT:-}"          # leave empty if unused
export PRISM_MAIL="${PRISM_MAIL:-}"                # leave empty to disable mail

# --- Environment ------------------------------------------------------------
# Pick ONE strategy and comment out the others.
prism_activate_env() {
  # 1) module system + venv (most common on HPC)
  if command -v module >/dev/null 2>&1; then
    module purge
    module load python/3.11 || true
    # module load cuda/12.1        # uncomment for GPU jobs
  fi

  if [[ -d "$PRISM_REPO/.venv" ]]; then
    # shellcheck disable=SC1091
    source "$PRISM_REPO/.venv/bin/activate"
  elif command -v uv >/dev/null 2>&1; then
    cd "$PRISM_REPO" && uv sync --all-extras
    # shellcheck disable=SC1091
    source "$PRISM_REPO/.venv/bin/activate"
  else
    echo "No environment found. Run 'make install' in $PRISM_REPO first." >&2
    exit 1
  fi

  # 2) container (uncomment instead of the above)
  # export PRISM_RUN="apptainer exec --nv $PRISM_REPO/prism.sif"
}

# --- Determinism ------------------------------------------------------------
# Hash randomization perturbs set/dict iteration order, which can change
# tie-breaking. Pin it so a rerun of the same commit + config matches.
export PYTHONHASHSEED=0
export PYTHONUNBUFFERED=1

# Keep BLAS from oversubscribing: Slurm already allocated the cores.
export OMP_NUM_THREADS="${SLURM_CPUS_PER_TASK:-1}"
export MKL_NUM_THREADS="${SLURM_CPUS_PER_TASK:-1}"
export OPENBLAS_NUM_THREADS="${SLURM_CPUS_PER_TASK:-1}"

# --- Provenance -------------------------------------------------------------
# Called by every template so a job's output records what actually ran.
prism_record_provenance() {
  local outdir="$1"
  mkdir -p "$outdir"
  {
    echo "job_id=${SLURM_JOB_ID:-local}"
    echo "array_task=${SLURM_ARRAY_TASK_ID:-none}"
    echo "node=$(hostname)"
    echo "submitted_from=${SLURM_SUBMIT_DIR:-$PWD}"
    echo "git_commit=$(git -C "$PRISM_REPO" rev-parse HEAD 2>/dev/null || echo unknown)"
    echo "git_dirty=$(git -C "$PRISM_REPO" status --porcelain 2>/dev/null | wc -l)"
    echo "python=$(python --version 2>&1)"
    echo "started_at=$(date -Is)"
  } > "$outdir/slurm_provenance.txt"

  # A dirty tree means the commit hash does not describe what ran.
  if [[ "$(git -C "$PRISM_REPO" status --porcelain 2>/dev/null | wc -l)" -ne 0 ]]; then
    echo "WARNING: working tree is dirty — git_commit does not fully describe this run." >&2
  fi
}
