# PRISM frontend configuration.
#
# Mode selects where data comes from. Both modes return the same TypeScript
# types, generated from the backend's OpenAPI schema.
#
#   mock -- committed demo fixtures in src/lib/demo/. These are generated by
#           running the real inference stack, so they are genuine model output,
#           not hand-written values. No backend required.
#   http -- call the FastAPI service.
NEXT_PUBLIC_PRISM_API_MODE=mock

# Backend base URL, used only when the mode is `http`.
NEXT_PUBLIC_PRISM_API_URL=http://localhost:8000

# Legacy pre-PRISM demo pages (/dashboard, /cycle, /chat) only.
# Leave empty to use their in-file stubs.
NEXT_PUBLIC_API_URL=
